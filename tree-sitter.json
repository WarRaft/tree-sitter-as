      "name": "angelscript",
      "camelcase": "AngelScript",
      "scope": "source.angelscript",
      "file-types": [
        "as", "angelscript"
      ]
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "AngelScript grammar for tree-sitter",
    "authors": [
      {
        "name": "nazarpunk",
        "email": "nazarpunk@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/WarRaft/tree-sitter-as"
    }
  },
